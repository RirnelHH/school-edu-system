// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============================================
// 账号与认证
// ============================================

model Account {
  id             String        @id @default(cuid())
  username       String        @unique
  password       String // bcrypt encrypted
  accountType    AccountType
  status         AccountStatus @default(ACTIVE)
  failedAttempts Int           @default(0)
  lockedUntil    DateTime?
  userId         String?       @unique
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  // 关联用户
  user User? @relation(fields: [userId], references: [id])

  @@map("accounts")
}

enum AccountType {
  STUDENT
  TEACHER
  ADMIN
}

enum AccountStatus {
  ACTIVE
  SUSPENDED
  LOCKED
}

// ============================================
// 用户与角色
// ============================================

model User {
  id           String   @id @default(cuid())
  name         String
  email        String?  @unique
  phone        String?
  wechatOpenid String?  @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // 账号关联
  account Account?

  // 角色关联
  userRoles UserRole[]

  // 如果是教师
  teacher Teacher?

  // 如果是学生
  student Student?

  @@map("users")
}

model Role {
  id          String   @id @default(cuid())
  code        String   @unique // student, teacher, admin, class_teacher, group_leader, department_head, director
  name        String
  description String?
  createdAt   DateTime @default(now())

  userRoles UserRole[]

  @@map("roles")
}

model UserRole {
  id         String     @id @default(cuid())
  userId     String
  roleId     String
  scopeType  ScopeType?
  scopeId    String? // classId, departmentId, etc.
  isActive   Boolean    @default(true)
  assignedAt DateTime   @default(now())
  expiresAt  DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId, scopeType, scopeId])
  @@map("user_roles")
}

enum ScopeType {
  SCHOOL
  DEPARTMENT
  GROUP
  CLASS
}

// ============================================
// 基础数据 - 学校/院系/专业
// ============================================

model School {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  address   String?
  contact   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  departments Department[]

  @@map("schools")
}

model Department {
  id        String   @id @default(cuid())
  schoolId  String
  name      String
  code      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  majors Major[]

  @@unique([schoolId, code])
  @@map("departments")
}

model Major {
  id           String   @id @default(cuid())
  departmentId String
  name         String
  code         String
  educationType EducationType @default(HIGH_TECH) // 高技/中技
  duration      Int        @default(3)             // 学制年限（3年/5年）
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  department            Department              @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  classes               Class[]
  courses               MajorCourse[]
  TalentDevelopmentPlan TalentDevelopmentPlan[]

  @@unique([departmentId, code])
  @@map("majors")
}

enum EducationType {
  HIGH_TECH  // 高技
  SECONDARY  // 中技
}

// ============================================
// 班级与学生
// ============================================

model Class {
  id           String   @id @default(cuid())
  majorId      String
  name         String
  grade        Int // 年级 1, 2, 3, 4, 5
  studentCount Int      @default(0)
  roomId       String?  // 关联教室
  enrollmentYear Int?    // 入学年份（可后续补充）
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  major          Major                 @relation(fields: [majorId], references: [id], onDelete: Cascade)
  students       Student[]
  classTeacher   Teacher?              @relation("ClassTeacher", fields: [classTeacherId], references: [id])
  classTeacherId String?
  teacherHistory ClassTeacherHistory[]
  room          Room?                @relation(fields: [roomId], references: [id])

  @@unique([majorId, name])
  @@map("classes")
}

model ClassTeacherHistory {
  id        String    @id @default(cuid())
  classId   String
  teacherId String
  startedAt DateTime
  endedAt   DateTime?
  reason    String?

  class Class @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@map("class_teacher_history")
}

model Student {
  id             String        @id @default(cuid())
  userId         String        @unique
  studentNumber  String        @unique
  classId        String
  enrollmentYear Int
  status         StudentStatus @default(ACTIVE)
  graduatedAt    DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  class           Class             @relation(fields: [classId], references: [id], onDelete: Cascade)
  grades          Grade[]
  checkIns        DailyCheckIn[]
  leaveRequests   LeaveRequest[]
  taskSubmissions TaskSubmission[]
  StudentPosition StudentPosition[]

  @@map("students")
}

enum StudentStatus {
  ACTIVE
  SUSPENDED
  WITHDRAWN
  GRADUATED
}

model StudentPosition {
  id           String    @id @default(cuid())
  studentId    String
  classId      String
  positionCode String // monitor, study_leader, PE_leader, etc.
  assignedAt   DateTime  @default(now())
  revokedAt    DateTime?

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, classId, positionCode])
  @@map("student_positions")
}

// ============================================
// 教师
// ============================================

model Teacher {
  id             String        @id @default(cuid())
  userId         String        @unique
  employeeNumber String        @unique
  title          String? // 职称
  specialty      String? // 特长
  status         TeacherStatus @default(ACTIVE)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  user                  User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  classes               Class[]                 @relation("ClassTeacher")
  courseHours           CourseHoursConfig[]
  teachingPlans         TeachingPlan[]
  TeacherTimePreference TeacherTimePreference[]
  TeachingHoursRecord   TeachingHoursRecord[]

  @@map("teachers")
}

enum TeacherStatus {
  ACTIVE
  SUSPENDED
}

// ============================================
// 学年学期
// ============================================

model AcademicYear {
  id              String   @id @default(cuid())
  year            String // "2024-2025"
  currentSemester Int? // 1 or 2
  startDate       DateTime
  endDate         DateTime
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  semesters Semester[]

  @@unique([year])
  @@map("academic_years")
}

model Semester {
  id             String   @id @default(cuid())
  academicYearId String
  number         Int // 1 or 2
  startDate      DateTime
  endDate        DateTime
  createdAt      DateTime @default(now())

  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)

  @@unique([academicYearId, number])
  @@map("semesters")
}

// ============================================
// 课程与课时
// ============================================

model Course {
  id         String         @id @default(cuid())
  code       String         @unique
  name       String
  category   CourseCategory
  credits    Float
  totalHours Int
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  majorCourses    MajorCourse[]
  grades          Grade[]
  taskSubmissions Task[]        @relation("TaskCourse")

  @@map("courses")
}

enum CourseCategory {
  PUBLIC // 公共课
  BASIC // 专业基础课
  PROFESSIONAL // 专业课
  PRACTICAL // 实践课
  ELECTIVE // 选修课
}

model MajorCourse {
  id            String @id @default(cuid())
  majorId       String
  courseId      String
  requiredHours Int? // 必修课时
  electiveHours Int? // 选修课时

  major  Major  @relation(fields: [majorId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([majorId, courseId])
  @@map("major_courses")
}

// ============================================
// 排课
// ============================================

model CourseHoursConfig {
  id          String   @id @default(cuid())
  teacherId   String
  courseId    String
  classId     String
  totalHours  Int
  theoryHours Int
  labHours    Int
  semesterId  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  teacher Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([teacherId, courseId, classId, semesterId])
  @@map("course_hours_config")
}

model TeacherTimePreference {
  id             String         @id @default(cuid())
  teacherId      String
  weekday        Int // 1-7
  periodStart    Int // 1-8
  periodEnd      Int
  preferenceType PreferenceType
  semesterId     String?
  createdAt      DateTime       @default(now())

  teacher Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([teacherId, weekday, periodStart, periodEnd, semesterId])
  @@map("teacher_time_preferences")
}

enum PreferenceType {
  UNAVAILABLE // 不可排（硬约束）
  PREFERRED // 优先排（软约束）
}

model ScheduleVersion {
  id            String                @id @default(cuid())
  semesterId    String
  versionNumber Int
  status        ScheduleVersionStatus @default(DRAFT)
  publishedAt   DateTime?
  createdAt     DateTime              @default(now())
  createdBy     String
  ScheduleEntry ScheduleEntry[]

  @@unique([semesterId, versionNumber])
  @@map("schedule_versions")
}

enum ScheduleVersionStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model ScheduleEntry {
  id                String     @id @default(cuid())
  scheduleVersionId String
  classId           String
  courseId          String
  teacherId         String
  roomId            String?
  weekday           Int
  periodStart       Int
  periodEnd         Int
  lessonType        LessonType
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  scheduleVersion    ScheduleVersion      @relation(fields: [scheduleVersionId], references: [id], onDelete: Cascade)
  ScheduleSuspension ScheduleSuspension[]

  @@index([scheduleVersionId, weekday, periodStart])
  @@map("schedule_entries")
}

enum LessonType {
  THEORY
  LAB
}

model ComputerRoom {
  id            String     @id @default(cuid())
  name          String
  building      String?
  capacity      Int
  computerCount Int
  status        RoomStatus @default(ACTIVE)
  createdAt     DateTime   @default(now())

  @@map("computer_rooms")
}

enum RoomStatus {
  ACTIVE
  MAINTENANCE
  RETIRED
}

model ScheduleSuspension {
  id              String    @id @default(cuid())
  scheduleEntryId String
  suspensionDate  DateTime
  reason          String
  makeupDate      DateTime?
  createdAt       DateTime  @default(now())

  scheduleEntry ScheduleEntry @relation(fields: [scheduleEntryId], references: [id], onDelete: Cascade)

  @@map("schedule_suspensions")
}

// ============================================
// 培养方案
// ============================================

model TalentDevelopmentPlan {
  id              String     @id @default(cuid())
  majorId         String
  grade           Int
  status          PlanStatus @default(DRAFT)
  version         Int        @default(1)
  submittedAt     DateTime?
  approvedAt      DateTime?
  rejectedAt      DateTime?
  rejectionReason String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  createdBy       String

  major       Major        @relation(fields: [majorId], references: [id], onDelete: Cascade)
  planCourses PlanCourse[]

  @@map("talent_development_plans")
}

enum PlanStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

model PlanCourse {
  id                   String @id @default(cuid())
  planId               String
  courseId             String
  semester             Int // 学期 1-6
  hoursPerWeek         Float?
  practiceHoursPercent Float?

  plan TalentDevelopmentPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@map("plan_courses")
}

// ============================================
// 成绩管理
// ============================================

model Grade {
  id          String      @id @default(cuid())
  studentId   String
  courseId    String
  semesterId  String
  usualScore  Float? // 平时分
  finalScore  Float? // 期末分
  totalScore  Float? // 总评分
  status      GradeStatus @default(DRAFT)
  submittedAt DateTime?
  reviewedAt  DateTime?
  publishedAt DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  Course  Course  @relation(fields: [courseId], references: [id])

  @@unique([studentId, courseId, semesterId])
  @@map("grades")
}

enum GradeStatus {
  DRAFT
  SUBMITTED
  REVIEWED
  PUBLISHED
}

// ============================================
// 请假审批
// ============================================

model LeaveRequest {
  id          String      @id @default(cuid())
  studentId   String
  type        LeaveType
  startDate   DateTime
  endDate     DateTime
  reason      String
  status      LeaveStatus @default(PENDING)
  currentStep Int         @default(1)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  student Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  steps   LeaveStep[]

  @@map("leave_requests")
}

enum LeaveType {
  PERSONAL // 事假
  SICK // 病假
  OTHER // 其他
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model LeaveStep {
  id             String          @id @default(cuid())
  leaveRequestId String
  step           Int
  approverType   ApproverType
  approverId     String?
  action         ApprovalAction?
  comment        String?
  actedAt        DateTime?

  leaveRequest LeaveRequest @relation(fields: [leaveRequestId], references: [id], onDelete: Cascade)

  @@map("leave_steps")
}

enum ApproverType {
  CLASS_TEACHER
  DIRECTOR
}

enum ApprovalAction {
  APPROVE
  REJECT
}

// ============================================
// 每日签到
// ============================================

model DailyCheckIn {
  id          String        @id @default(cuid())
  studentId   String
  checkInTime DateTime      @default(now())
  latitude    Float?
  longitude   Float?
  status      CheckInStatus
  isLate      Boolean       @default(false)
  lateMinutes Int           @default(0)
  createdAt   DateTime      @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, checkInTime])
  @@map("daily_check_ins")
}

enum CheckInStatus {
  CHECKED_IN
  LATE
  ABSENT
}

// ============================================
// 任务与作业
// ============================================

model Task {
  id          String     @id @default(cuid())
  courseId    String?
  classId     String?
  title       String
  description String?
  deadline    DateTime
  attachments Json? // [{name, url}]
  status      TaskStatus @default(DRAFT)
  publishedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  course      Course?          @relation("TaskCourse", fields: [courseId], references: [id])
  submissions TaskSubmission[]

  @@map("tasks")
}

enum TaskStatus {
  DRAFT
  PUBLISHED
  CLOSED
}

model TaskSubmission {
  id          String           @id @default(cuid())
  taskId      String
  studentId   String
  content     String?
  attachment  Json?
  status      SubmissionStatus @default(SUBMITTED)
  submittedAt DateTime         @default(now())
  gradedAt    DateTime?
  score       Float?
  feedback    String?

  task    Task    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([taskId, studentId])
  @@map("task_submissions")
}

enum SubmissionStatus {
  SUBMITTED
  LATE
  GRADED
}

// ============================================
// 教师课时统计
// ============================================

model TeachingHoursCoefficient {
  id         String          @id @default(cuid())
  semesterId String
  type       CoefficientType
  config     Json // 根据type不同存储不同配置
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@unique([semesterId, type])
  @@map("teaching_hours_coefficients")
}

enum CoefficientType {
  REPEAT_CLASS // 重复课时系数
  CLASS_SIZE // 班级人数系数
}

model TeachingHoursRecord {
  id                String   @id @default(cuid())
  teacherId         String
  semesterId        String
  courseId          String
  classId           String
  originalHours     Int
  repeatCoefficient Float    @default(1.0)
  sizeCoefficient   Float    @default(1.0)
  finalHours        Float
  suspensionHours   Int      @default(0)
  createdAt         DateTime @default(now())

  teacher Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([teacherId, semesterId, courseId, classId])
  @@map("teaching_hours_records")
}

// ============================================
// 教材管理
// ============================================

model Textbook {
  id        String   @id @default(cuid())
  isbn      String   @unique
  title     String
  author    String
  publisher String
  price     Float
  coverUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orderItems TextbookOrderItem[]

  @@map("textbooks")
}

model TextbookOrder {
  id          String      @id @default(cuid())
  semesterId  String
  applicantId String
  status      OrderStatus @default(PENDING)
  reviewedAt  DateTime?
  reviewedBy  String?
  approvedAt  DateTime?
  approvedBy  String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  items TextbookOrderItem[]

  @@map("textbook_orders")
}

enum OrderStatus {
  PENDING
  REVIEWED
  APPROVED
  REJECTED
  PROCURED
}

model TextbookOrderItem {
  id          String @id @default(cuid())
  orderId     String
  textbookId  String
  quantity    Int
  unitPrice   Float
  receivedQty Int    @default(0)

  order    TextbookOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  textbook Textbook      @relation(fields: [textbookId], references: [id], onDelete: Cascade)

  @@map("textbook_order_items")
}

// ============================================
// 退学处理
// ============================================

model WithdrawalRequest {
  id             String           @id @default(cuid())
  studentId      String
  reason         String
  withdrawalDate DateTime
  status         WithdrawalStatus @default(PENDING)
  approvedAt     DateTime?
  approvedBy     String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@map("withdrawal_requests")
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
}

// ============================================
// 授课计划与教案
// ============================================

model TeachingPlan {
  id           String             @id @default(cuid())
  teacherId    String
  courseId     String
  semesterId   String
  academicYear String
  status       TeachingPlanStatus @default(DRAFT)
  submittedAt  DateTime?
  reviewedAt   DateTime?
  reviewedBy   String?
  approvedAt   DateTime?
  approvedBy   String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  teacher Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([teacherId, courseId, semesterId])
  @@map("teaching_plans")
}

enum TeachingPlanStatus {
  DRAFT
  SUBMITTED
  REVIEWED
  APPROVED
  REJECTED
}

// ============================================
// 登录日志
// ============================================

model LoginLog {
  id            String   @id @default(cuid())
  accountId     String
  ip            String?
  device        String?
  userAgent     String?
  success       Boolean
  failureReason String?
  createdAt     DateTime @default(now())

  @@index([accountId, createdAt])
  @@map("login_logs")
}

// ============================================
// 场地管理（教室/机房/画室/网络布线室）
// ============================================
enum RoomType {
  CLASSROOM      // 普通教室
  COMPUTER_LAB   // 机房
  ART_STUDIO     // 画室
  NETWORK_LAB    // 网络综合布线室
}

model Room {
  id        String     @id @default(cuid())
  name      String
  type      RoomType
  capacity  Int
  building  String?
  status    RoomStatus @default(ACTIVE)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  classes Class[]

  @@map("rooms")
}

// ============================================
// 学期周数配置
// ============================================
model SemesterWeekConfig {
  id           String  @id @default(cuid())
  semesterId   String  @unique
  isGraduating Boolean @default(false) // 是否毕业班
  weekCount    Int     @default(18)    // 周数

  @@map("semester_week_configs")
}

// ============================================
// 师资课程模板
// ============================================
model TeacherCourseTemplate {
  id                    String          @id @default(cuid())
  teacherId             String
  semesterId             String
  courseId               String
  courseName             String          // 冗余存储课程名称便于显示
  weekHours              Int             // 周节数
  totalHours             Int             // 总课时
  theoryHours            Int             // 理论课时
  practiceHours           Int             // 上机课时
  practiceHoursPercent    Float           // 上机比例 0.0-1.0
  
  // 合班教学班信息 [{classId, className, studentCount}]
  teachingClasses        Json
  
  recommendedRoomType    RoomType?       // 推荐机房类型
  preferredSlots          Json?           // 优先排课区间 [{dayOfWeek, periodStart, periodEnd}]
  forbiddenSlots          Json?           // 不可排课区间
  
  status                  TemplateStatus  @default(DRAFT)
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt
  createdBy               String

  @@map("teacher_course_templates")
}

enum TemplateStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}
